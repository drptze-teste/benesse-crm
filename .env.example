# GEMINI_API_KEY: usada SOMENTE no servidor (server.ts) para as rotas /api/ai/*.
# Não é mais injetada no bundle do browser. Configure no ambiente (Cloud Run / .env local).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: opcional. Modelo Gemini usado pelo backend (default: gemini-2.0-flash).
GEMINI_MODEL="gemini-2.0-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
WHATSAPP_VERIFY_TOKEN="benesse_crm_token"
